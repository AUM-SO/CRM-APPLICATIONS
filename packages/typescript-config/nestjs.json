{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "NestJS",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2021",
    "lib": ["es2021"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "declaration": true,
    "declarationMap": true,
    "incremental": false,
    "resolveJsonModule": true,
    "sourceMap": true
  }
}
